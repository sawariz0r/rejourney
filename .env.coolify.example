# ============================================================================
# rejourney — Coolify environment variables
# Paste this into Coolify → your resource → Environment Variables (bulk editor).
# Secrets below are freshly generated; regenerate any you like.
# Fill in every <PLACEHOLDER>. Leave the OPTIONAL block commented unless used.
# ============================================================================

# ---- Image / logging --------------------------------------------------------
IMAGE_TAG=latest
LOG_LEVEL=info

# ---- Domains (bare hostnames — must have DNS A records before deploy) -------
API_DOMAIN=api.rejourney.example.com
INGEST_DOMAIN=ingest.rejourney.example.com
DASHBOARD_DOMAIN=app.rejourney.example.com
WWW_DOMAIN=www.rejourney.example.com

# ---- Public URLs (full https origins handed to browsers/clients) -----------
PUBLIC_API_URL=https://api.rejourney.example.com
PUBLIC_INGEST_URL=https://ingest.rejourney.example.com
PUBLIC_DASHBOARD_URL=https://app.rejourney.example.com
DASHBOARD_ORIGIN=https://app.rejourney.example.com

# ---- Postgres ---------------------------------------------------------------
POSTGRES_DB=rejourney
POSTGRES_USER=rejourney
POSTGRES_PASSWORD=7ce6809cdc13dd8b35cc897683bcf4000a18066182d2b975

# ---- Redis ------------------------------------------------------------------
REDIS_PASSWORD=2d93322f912d7545b974bf06cb28a700ae5361f9c703e35a

# ---- Connection strings (hostnames = compose service names; NOT auto-built) -
DATABASE_URL=postgresql://rejourney:7ce6809cdc13dd8b35cc897683bcf4000a18066182d2b975@postgres:5432/rejourney
REDIS_URL=redis://:2d93322f912d7545b974bf06cb28a700ae5361f9c703e35a@redis:6379

# ---- App secrets ------------------------------------------------------------
JWT_SECRET=ac79dd7c7072c7bb6a8b1b316b4a4588b395e1755880419403932b71cdfc8cf6
JWT_SIGNING_KEY=347b14b15235611479c1043f916d2460714725b1afd1590bf38393cab43106a7
INGEST_HMAC_SECRET=234d166723ffb1673774a50f921dafbd6796f3d127986eeb365d5e95b46fd36b
STORAGE_ENCRYPTION_KEY=cf4b60799bc74845a34f5afe5382791404440e88f8c09a33e045cbcf5585cdd0

# ---- Object storage (S3-compatible — REQUIRED) -----------------------------
# Hetzner Object Storage example endpoint shown; swap for your provider.
S3_ENDPOINT=https://<region>.your-objectstorage.com
S3_PUBLIC_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=rejourney
S3_ACCESS_KEY_ID=<S3_ACCESS_KEY_ID>
S3_SECRET_ACCESS_KEY=<S3_SECRET_ACCESS_KEY>

# ============================================================================
# OPTIONAL — uncomment + fill only what you use. All have safe empty defaults.
# ============================================================================
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@rejourney.example.com
# SMTP_SECURE=true
