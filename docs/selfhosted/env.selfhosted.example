# Rejourney self-hosted configuration example
# Copy to .env.selfhosted and fill in values, or let ./scripts/selfhosted/deploy.sh create it.

BASE_DOMAIN=example.com
DASHBOARD_DOMAIN=example.com
WWW_DOMAIN=www.example.com
API_DOMAIN=api.example.com
INGEST_DOMAIN=ingest.example.com
PUBLIC_DASHBOARD_URL=https://example.com
PUBLIC_API_URL=https://api.example.com
PUBLIC_INGEST_URL=https://ingest.example.com
DASHBOARD_ORIGIN=https://example.com
LETSENCRYPT_EMAIL=admin@example.com

POSTGRES_USER=rejourney
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=rejourney
DATABASE_URL=postgresql://rejourney:CHANGE_ME@postgres:5432/rejourney

REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# minio or s3
STORAGE_BACKEND=minio

# Built-in MinIO defaults
MINIO_ROOT_USER=rejourney
MINIO_ROOT_PASSWORD=CHANGE_ME
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=
S3_BUCKET=rejourney
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=rejourney
S3_SECRET_ACCESS_KEY=CHANGE_ME

# External S3 example
# STORAGE_BACKEND=s3
# MINIO_ROOT_USER=
# MINIO_ROOT_PASSWORD=
# S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# S3_PUBLIC_ENDPOINT=https://s3.us-east-1.amazonaws.com
# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key

JWT_SECRET=CHANGE_ME_64_HEX
JWT_SIGNING_KEY=CHANGE_ME_64_HEX
INGEST_HMAC_SECRET=CHANGE_ME_64_HEX
STORAGE_ENCRYPTION_KEY=CHANGE_ME_64_HEX
SUPERWALL_API_KEY_ENCRYPTION_KEY=CHANGE_ME_64_HEX
REVENUECAT_API_KEY_ENCRYPTION_KEY=CHANGE_ME_64_HEX

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
SMTP_SECURE=true

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

IMAGE_TAG=latest
LOG_LEVEL=info
