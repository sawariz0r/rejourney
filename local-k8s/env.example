# Local Kubernetes development environment
# Copy to .env.k8s.local and adjust only the values you need.

NODE_ENV=development
PORT=3000
LOG_LEVEL=info
SELF_HOSTED_MODE=false
COOKIE_SECURE=false

POSTGRES_USER=rejourney
POSTGRES_PASSWORD=rejourney
POSTGRES_DB=rejourney
DATABASE_URL=postgresql://rejourney:rejourney@127.0.0.1:5432/rejourney

REDIS_URL=redis://127.0.0.1:6379/0

CLICKHOUSE_ENABLED=true
CLICKHOUSE_DUAL_WRITE_ENABLED=true
CLICKHOUSE_READS_ENABLED=true
CLICKHOUSE_URL=http://127.0.0.1:30123
CLICKHOUSE_K8S_URL=http://clickhouse:8123
CLICKHOUSE_USER=rejourney
CLICKHOUSE_PASSWORD=rejourney
CLICKHOUSE_DATABASE=rejourney

S3_ENDPOINT=http://127.0.0.1:9000
S3_PUBLIC_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=rejourney
S3_ACCESS_KEY_ID=rejourney
S3_SECRET_ACCESS_KEY=rejourney-dev-secret

RESEARCH_LAKE_ENABLED=false
RESEARCH_LAKE_ENDPOINT=http://127.0.0.1:9000
RESEARCH_LAKE_BUCKET=rejourney-research-lake-local
RESEARCH_LAKE_REGION=us-east-1
RESEARCH_LAKE_ACCESS_KEY_ID=rejourney
RESEARCH_LAKE_SECRET_ACCESS_KEY=rejourney-dev-secret
RESEARCH_LAKE_HASH_SECRET=replace_with_openssl_rand_hex_32

JWT_SECRET=replace_with_openssl_rand_hex_32
JWT_SIGNING_KEY=replace_with_openssl_rand_hex_32
INGEST_HMAC_SECRET=replace_with_openssl_rand_hex_32
STORAGE_ENCRYPTION_KEY=replace_with_openssl_rand_hex_32
SUPERWALL_API_KEY_ENCRYPTION_KEY=replace_with_openssl_rand_hex_32
REVENUECAT_API_KEY_ENCRYPTION_KEY=replace_with_openssl_rand_hex_32

PUBLIC_DASHBOARD_URL=http://127.0.0.1:8080
PUBLIC_API_URL=http://127.0.0.1:3000
VITE_API_URL=http://127.0.0.1:3000
PUBLIC_INGEST_URL=http://127.0.0.1:3001
DASHBOARD_ORIGIN=http://127.0.0.1:8080
ADDITIONAL_DASHBOARD_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://rejourney.localtest.me,http://rejourney.localtest.me:8080
OAUTH_REDIRECT_BASE=http://127.0.0.1:3000

QUERY_BUILDER_KEY=
QUERY_BUILDER_MODEL=gemini-3.1-flash-lite-preview

SHOW_ISSUE_DETECTION_UI=false
ISSUE_DETECTION_API_URL=
ISSUE_DETECTION_SERVICE_SECRET=
GITHUB_APP_SLUG=
GITHUB_APP_STATE_SECRET=
REJOURNEY_INTERNAL_API_URL=https://api.rejourney.co
REJOURNEY_INTERNAL_SERVICE_SECRET=

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_MAPBOX_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
