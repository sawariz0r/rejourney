{
  "name": "rejourney-monorepo",
  "version": "4.0.0",
  "private": true,
  "description": "Rejourney Monorepo - Session Recording Platform",
  "workspaces": [
    "packages/*",
    "backend",
    "dashboard/web-ui"
  ],
  "scripts": {
    "dev": "./scripts/local-k8s/dev.sh",
    "dev:resume": "./scripts/local-k8s/dev.sh resume",
    "dev:full": "./scripts/local-k8s/deploy.sh full",
    "ci:local": "./scripts/local-k8s/rejourney-ci.sh full",
    "ci:local:fast": "./scripts/local-k8s/rejourney-ci.sh fast",
    "ci:local:checks": "./scripts/local-k8s/rejourney-ci.sh checks",
    "ci:local:deploy": "./scripts/local-k8s/rejourney-ci.sh deploy",
    "dev:down": "./scripts/local-k8s/dev.sh down",
    "dev:logs": "./scripts/local-k8s/dev.sh logs",
    "build": "npm run build:sdk",
    "build:react-native": "cd packages/react-native && npm run prepack",
    "build:browser": "cd packages/browser && npm run prepack",
    "build:sdk": "npm run build:react-native && npm run build:browser",
    "build:clean": "npm run clean && npm run build:sdk",
    "test": "npm run test --workspaces --if-present",
    "security:audit": "npm audit --omit=dev",
    "security:audit:all": "npm audit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "docs:localize": "node scripts/localize-docs.mjs",
    "docs:localize:audit": "node scripts/audit-localized-docs.mjs",
    "docs:localize:web": "DOCS=web/getting-started.md node scripts/localize-docs.mjs",
    "docs:localize:web:audit": "DOCS=web/getting-started.md node scripts/audit-localized-docs.mjs",
    "clean": "rm -rf packages/react-native/lib packages/browser/dist",
    "db:seed": "cd backend && npm run db:seed",
    "example:boilerplate": "cd examples/react-native-boilerplate && npm run dev",
    "example:brew": "cd examples/brew-coffee-labs && npm start",
    "example:bare": "cd examples/react-native-bare && npm start",
    "example:web-next": "cd examples/web-next && npm run dev",
    "example:web-sveltekit": "cd examples/web-sveltekit && npm run dev",
    "example:web-nuxt": "cd examples/web-nuxt && npm run dev",
    "example:swift": "open examples/swift-clean-arch/CountriesSwiftUI.xcodeproj",
    "example:boilerplate:ios": "cd examples/react-native-boilerplate && npm run ios",
    "example:boilerplate:android": "cd examples/react-native-boilerplate && npm run android",
    "example:brew:ios": "cd examples/brew-coffee-labs && npm run ios",
    "example:brew:android": "cd examples/brew-coffee-labs && npm run android",
    "example:bare:ios": "cd examples/react-native-bare && npm run ios",
    "example:bare:android": "cd examples/react-native-bare && npm run android",
    "example:swift:sdk:old": "cd examples/swift-clean-arch && bash ./scripts/switch-rejourney-sdk.sh --old",
    "example:swift:sdk:new": "cd examples/swift-clean-arch && bash ./scripts/switch-rejourney-sdk.sh --new",
    "example:swift:sdk:status": "cd examples/swift-clean-arch && bash ./scripts/switch-rejourney-sdk.sh --status",
    "postinstall": "npm run build:sdk"
  },
  "repository": "https://github.com/rejourneyco/rejourney",
  "author": "Rejourney",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "eslint": "^8.36.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tar": "^7.5.7",
    "qs": "^6.15.0",
    "esbuild": "^0.25.0",
    "fast-xml-parser": "^5.3.4",
    "nodemailer": "^8.0.1",
    "minimatch": "^10.2.2",
    "postcss": "^8.5.10"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
