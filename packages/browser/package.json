{
  "name": "@rejourneyco/browser",
  "version": "0.0.0",
  "description": "Rejourney web analytics and session replay SDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "!src/__tests__",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "README.md",
    "LICENSE-APACHE"
  ],
  "scripts": {
    "version:sync": "node ./scripts/generate-version.cjs",
    "build": "tsc -p tsconfig.json",
    "prebuild": "npm run version:sync",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build && npm run verify:package",
    "pretest": "npm run version:sync",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretypecheck": "npm run version:sync",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify:package": "node ./scripts/verify-package-content.js"
  },
  "keywords": [
    "session-replay",
    "web-analytics",
    "rrweb",
    "observability",
    "rejourney"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rejourneyco/rejourney"
  },
  "author": "Rejourney",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/integrations/react.d.ts",
      "import": "./dist/integrations/react.js"
    },
    "./next": {
      "types": "./dist/integrations/next.d.ts",
      "import": "./dist/integrations/next.js"
    },
    "./vue": {
      "types": "./dist/integrations/vue.d.ts",
      "import": "./dist/integrations/vue.js"
    },
    "./nuxt": {
      "types": "./dist/integrations/nuxt.d.ts",
      "import": "./dist/integrations/nuxt.js"
    },
    "./svelte": {
      "types": "./dist/integrations/svelte.d.ts",
      "import": "./dist/integrations/svelte.js"
    },
    "./angular": {
      "types": "./dist/integrations/angular.d.ts",
      "import": "./dist/integrations/angular.js"
    },
    "./remix": {
      "types": "./dist/integrations/remix.d.ts",
      "import": "./dist/integrations/remix.js"
    },
    "./astro": {
      "types": "./dist/integrations/astro.d.ts",
      "import": "./dist/integrations/astro.js"
    },
    "./gatsby": {
      "types": "./dist/integrations/gatsby.d.ts",
      "import": "./dist/integrations/gatsby.js"
    }
  },
  "dependencies": {
    "@rrweb/packer": "2.0.0-alpha.20",
    "@rrweb/record": "2.0.0-alpha.20",
    "@rrweb/replay": "2.0.0-alpha.20",
    "@rrweb/rrweb-plugin-console-record": "2.0.0-alpha.20",
    "@rrweb/rrweb-plugin-console-replay": "2.0.0-alpha.20",
    "fflate": "^0.8.2",
    "isbot": "^5.1.40"
  },
  "peerDependencies": {
    "@angular/core": ">=16",
    "@angular/router": ">=16",
    "@remix-run/react": ">=2",
    "@sveltejs/kit": ">=2",
    "gatsby": ">=5",
    "next": ">=13",
    "nuxt": ">=3",
    "react": ">=18",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": true
    },
    "@angular/router": {
      "optional": true
    },
    "@remix-run/react": {
      "optional": true
    },
    "@sveltejs/kit": {
      "optional": true
    },
    "gatsby": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "*",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
